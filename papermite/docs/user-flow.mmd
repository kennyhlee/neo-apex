    style InferType fill:#0969DA,color:#fff,stroke:none
    style Review fill:#1A7F37,color:#fff,stroke:none
    style ConfirmPage fill:#8250DF,color:#fff,stroke:none
    style Commit fill:#1A7F37,color:#fff,stroke:none
    style NoChange fill:#6e7781,color:#fff,stroke:none
    style StayReview fill:#6e7781,color:#fff,stroke:none
    style ModelCard fill:#CF8A2E,color:#fff,stroke:none
